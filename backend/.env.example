# Copy this file to backend/.env for local development.
# backend/.env is intentionally local-only and should not be committed.

# Provider mode:
# - mock: offline/demo-safe provider for local development
# - verba: live Verba provider for report generation and deployed image analysis
AI_PROVIDER=verba

# Optional: override the public Verba API base URL if Verba changes it.
VERBA_API_BASE_URL=https://api.verba.ink

# Verba mode only:
VERBA_API_KEY=vka_real_api_key
VERBA_CAPTURE_CHARACTER=works_capture_ai
VERBA_REPORT_CHARACTER=works_report_ai

# Required only for Verba image analysis.
# This must be a publicly reachable HTTPS URL to your backend so Verba can fetch /api/uploads/{file}.
# Railway URL example:
# PUBLIC_API_BASE_URL=https://your-backend.up.railway.app
#
# Local localhost URLs are not public and will fail explicitly for Verba photo analysis.
# For local testing, use Railway or an HTTPS tunnel such as ngrok/cloudflared.

# Optional: comma-separated explicit origins for web clients.
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: regex for local-network or Netlify access. Override only if needed.
# CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|[a-z0-9-]+\.netlify\.app|192\.168\.\d{1,3}\.\d{1,3}|10\.\d{1,3}\.\d{1,3}\.\d{1,3}|172\.(1[6-9]|2\d|3[0-1])\.\d{1,3}\.\d{1,3})(:\d+)?$
